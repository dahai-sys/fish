<%- include('../partials/head', { title: '添加船只 · 鱼多多' }) %>
<h3 class="mb-3"><i class="bi bi-water"></i> 添加船只</h3>
<div class="row">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-body">
        <form method="POST" action="/captain/boats">
          <h6 class="text-muted border-bottom pb-2">基本信息</h6>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label">船名 *</label>
              <input class="form-control" name="name" value="<%= values.name || '' %>" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">船只类型 *</label>
              <select class="form-select" name="boat_type" required>
                <option value="">请选择</option>
                <% ['出海艇','近海艇','筏钓艇','休闲渔船','专业钓艇','其他'].forEach(t => { %>
                  <option value="<%= t %>" <%= values.boat_type===t ? 'selected' : '' %>><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">载客座位数 *</label>
              <input type="number" class="form-control" name="seats" value="<%= values.seats || '' %>" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">船体长度（米）</label>
              <input type="number" step="0.1" class="form-control" name="length_m" value="<%= values.length_m || '' %>">
            </div>
            <div class="col-md-8">
              <label class="form-label">主打垂钓鱼种</label>
              <input class="form-control" name="target_fish" value="<%= values.target_fish || '' %>" placeholder="如 鲈鱼/真鲷/石斑">
            </div>
            <div class="col-md-6">
              <label class="form-label">船长从业经验</label>
              <input class="form-control" name="captain_experience" value="<%= values.captain_experience || '' %>" placeholder="如 15年海钓经验">
            </div>
          </div>

          <h6 class="text-muted border-bottom pb-2">费用与包团</h6>
          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <label class="form-label">散客每座价格 ¥</label>
              <input type="number" step="1" class="form-control" name="price_per_seat" value="<%= values.price_per_seat || '' %>" placeholder="如 550">
            </div>
            <div class="col-md-4">
              <label class="form-label">包团最少人数</label>
              <input type="number" class="form-control" name="charter_min_people" value="<%= values.charter_min_people || '' %>" placeholder="如 18">
            </div>
            <div class="col-md-4">
              <label class="form-label">包团说明</label>
              <input class="form-control" name="charter_note" value="<%= values.charter_note || '' %>" placeholder="如 包团时间可改，欢迎查詢">
            </div>
            <div class="col-12">
              <label class="form-label">费用包含</label>
              <input class="form-control" name="price_includes" value="<%= values.price_includes || '' %>" placeholder="如 饮用水1支、杯麵1個、冰、南極蝦共享">
              <div class="form-text">钓友最关心的"这钱含什么"，建议逐项列出</div>
            </div>
          </div>

          <h6 class="text-muted border-bottom pb-2">船上设施</h6>
          <div class="mb-3">
            <label class="form-label">设施清单（逗号分隔）</label>
            <input class="form-control" name="facilities" value="<%= values.facilities || '' %>" placeholder="如 頂流機,洗手間,熱水,微波爐,活魚艙">
            <div class="form-text">详情页会自动拆成标签展示</div>
          </div>

          <h6 class="text-muted border-bottom pb-2">联系方式</h6>
          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <label class="form-label">联系电话</label>
              <input class="form-control" name="contact_phone" value="<%= values.contact_phone || '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">WhatsApp 报名链接</label>
              <input class="form-control" name="whatsapp_link" value="<%= values.whatsapp_link || '' %>" placeholder="https://wa.me/852xxxxxxxx">
            </div>
            <div class="col-md-4">
              <label class="form-label">微信号</label>
              <input class="form-control" name="wechat" value="<%= values.wechat || '' %>" placeholder="如 Eco96441883">
              <div class="form-text">详情页可点击复制</div>
            </div>
          </div>

          <h6 class="text-muted border-bottom pb-2">综合介绍</h6>
          <div class="mb-3">
            <label class="form-label">船只描述</label>
            <textarea class="form-control" name="description" rows="3"><%= values.description || '' %></textarea>
          </div>

          <div class="mt-3">
            <button class="btn btn-primary"><i class="bi bi-check-lg"></i> 保存</button>
            <a href="/captain/boats" class="btn btn-outline-secondary">取消</a>
          </div>
          <div class="form-text mt-3">
            保存后可继续：上传图集、添加多个上船地点（带各自出发时间）、设置钓区、发布船期
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
