<%- include('../partials/head', { title: '注册' }) %>
<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h4 class="mb-3 text-center"><i class="bi bi-person-plus"></i> 注册账号</h4>
        <form method="POST" action="/register">
          <div class="mb-3">
            <label class="form-label">我是 *</label>
            <div class="d-flex gap-3">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="role" id="r-angler" value="angler" <%= values.role!=='captain' ? 'checked' : '' %>>
                <label class="form-check-label" for="r-angler">🎣 钓鱼人</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="role" id="r-captain" value="captain" <%= values.role==='captain' ? 'checked' : '' %>>
                <label class="form-check-label" for="r-captain">🚢 船长</label>
              </div>
            </div>
            <div class="form-text">钓鱼人可浏览预约船期；船长可发布船只与船期。</div>
          </div>
          <div class="mb-3">
            <label class="form-label">姓名/昵称 *</label>
            <input class="form-control" name="name" value="<%= values.name || '' %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label">用户名 *</label>
            <input class="form-control" name="username" value="<%= values.username || '' %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label">手机号</label>
            <input class="form-control" name="phone" value="<%= values.phone || '' %>">
          </div>
          <div class="mb-3">
            <label class="form-label">密码 *</label>
            <input type="password" class="form-control" name="password" required>
          </div>
          <div class="mb-3">
            <label class="form-label">确认密码 *</label>
            <input type="password" class="form-control" name="confirm" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">注册</button>
        </form>
        <div class="text-center mt-3 small">
          已有账号？<a href="/login">去登录</a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/foot') %>
