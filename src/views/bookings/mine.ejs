<%- include('../partials/head', { title: '我的预约' }) %>
<h3 class="mb-3"><i class="bi bi-bookmark-check"></i> 我的预约</h3>

<% if (bookings.length === 0) { %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-inbox display-6 d-block mb-2"></i>
    还没有预约记录
    <div class="mt-3"><a href="/boats" class="btn btn-outline-primary btn-sm">去浏览船只</a></div>
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>船期</th>
          <th>出发</th>
          <th>船只/船长</th>
          <th class="text-center">座位</th>
          <th class="text-center">金额</th>
          <th class="text-center">状态</th>
          <th class="text-center">操作</th>
        </tr>
      </thead>
      <tbody>
        <% bookings.forEach(b => {
          const total = b.seats_booked * b.price_per_seat;
          const statusMap = { pending:['待确认','warning'], confirmed:['已确认','success'], cancelled:['已取消','secondary'], completed:['已完成','info'] };
          const [label, cls] = statusMap[b.status];
        %>
          <tr>
            <td>
              <a href="/boats/<%= b.boat_id %>"><%= b.boat_name %></a>
              <div class="small text-muted"><%= b.meeting_port || '' %></div>
            </td>
            <td><%= b.depart_date %><br><small class="text-muted"><%= b.depart_time || '' %></small></td>
            <td>
              <%= b.boat_name %><br>
              <small class="text-muted"><%= b.captain_name %> <%= b.captain_phone ? '· '+b.captain_phone : '' %></small>
            </td>
            <td class="text-center"><%= b.seats_booked %></td>
            <td class="text-center">¥<%= total %></td>
            <td class="text-center"><span class="badge text-bg-<%= cls %>"><%= label %></span></td>
            <td class="text-center">
              <% if (b.status === 'pending' || b.status === 'confirmed') { %>
                <form method="POST" action="/bookings/<%= b.id %>/cancel" class="d-inline"
                      onsubmit="return confirm('确定取消该预约吗？')">
                  <button class="btn btn-sm btn-outline-danger">取消</button>
                </form>
              <% } else { %>
                <span class="text-muted small">—</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
<%- include('../partials/foot') %>
